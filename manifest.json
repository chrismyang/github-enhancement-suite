{
  "manifest_version": 3,
  "name": "GitHub Enhancement Suite",
  "version": "1.0.1",
  "description": "Better GitHub editing: Tab-indent markdown lists, monospace editor, Ctrl+; to search issue links, 'e' to quick-edit comments.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "GitHub Enhancement Suite",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["src/indent.js", "src/issue-search.js", "src/issue-search-ui.js", "src/quick-edit.js", "src/content.js"],
      "css": ["src/editor.css", "src/issue-search.css", "src/quick-edit.css"],
      "run_at": "document_idle"
    }
  ]
}
